# Chef workspace environment
#
# Copy this file to `.env` for local development.
# Do not commit real secrets.

# API
PORT=3001
# Docker Compose exposes the project Postgres container on localhost:5433.
# If you use a locally installed Postgres server instead, change this to
# localhost:5432 or whatever port your local server uses.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cart_generator?schema=public
# Optional shared Supabase database. Prisma uses DATABASE_URL for runtime and
# DIRECT_URL for migrations when both are present.
# Prefer copying these URLs directly from Supabase. If your password contains
# special characters like @, keep the URL quoted or percent-encoded.
SUPABASE_DATABASE_URL="postgresql://postgres.[project-ref]:[encoded-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
SUPABASE_DIRECT_URL="postgresql://postgres.[project-ref]:[encoded-password]@aws-0-[region].pooler.supabase.com:5432/postgres"
DIRECT_URL=
AUTH_JWT_SECRET=replace-with-a-long-random-local-secret
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Web
API_BASE_URL=http://localhost:3001/api/v1

# Google auth
# Used by the API to verify Google ID tokens.
GOOGLE_CLIENT_ID=
# Used by the web Google sign-in button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Kroger live product search
# Keep false unless you have valid credentials.
KROGER_USE_REAL_PROVIDER=false
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Instacart Developer Platform handoff
# Development base URL: https://connect.dev.instacart.tools
# Production base URL: https://connect.instacart.com
INSTACART_USE_REAL_PROVIDER=false
INSTACART_API_KEY=
INSTACART_ENV=development
INSTACART_API_BASE_URL=https://connect.dev.instacart.tools

# Walmart provider boundary
# Currently inactive by default.
WALMART_USE_REAL_PROVIDER=false
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
WALMART_ENV=sandbox

# LLM recipe generation and editing
# mock works in the Streamlit testing lab without API keys.
CHEF_LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_RATE_LIMIT_WINDOW_MS=600000
AI_RATE_LIMIT_MAX_REQUESTS=5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
