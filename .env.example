# Chef workspace environment
#
# Copy this file to `.env` for local development.
# Do not commit real secrets.

# API
PORT=3001
# Docker Compose exposes the project Postgres container on localhost:5433.
# If you use a locally installed Postgres server instead, change this to
# localhost:5432 or whatever port your local server uses.
###DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cart_generator?schema=public
# Optional shared Supabase database. Prisma uses DATABASE_URL for runtime and
# DIRECT_URL for migrations when both are present.
# Prefer copying these URLs directly from Supabase. If your password contains
# special characters like @, keep the URL quoted or percent-encoded.
SUPABASE_DATABASE_URL="postgresql://postgres.[project-ref]:[encoded-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
SUPABASE_DIRECT_URL="postgresql://postgres.[project-ref]:[encoded-password]@aws-0-[region].pooler.supabase.com:5432/postgres"
###DIRECT_URL=
AUTH_JWT_SECRET=replace-with-a-long-random-local-secret
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_EXPIRES_IN_DAYS=30
# Comma-separated allowed browser origins for API CORS.
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://chef.postigo.sh,https://www.chef.postigo.sh
# Leave unset locally to expose Swagger docs. Set false/omit in production.
API_ENABLE_DOCS=
# Request body guardrails.
API_JSON_BODY_LIMIT=10mb
API_URLENCODED_BODY_LIMIT=1mb
# Auth endpoint rate limits.
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_REFRESH_RATE_LIMIT_MAX_REQUESTS=30

# Web
API_BASE_URL=http://localhost:3001/api/v1
# Optional. Leave unset to let Next use its default local port 3000.
WEB_PORT=
# Optional recipe image enrichment used by the web app.
UNSPLASH_ACCESS_KEY=

# Vision
# Nest proxies real photo/video scans to the Python sidecar.
# Lab-only web inventory Live/Photo/Video scan proxy. Leave unset/false for
# production and mainline local development.
VISION_SCAN_LAB_ENABLED=false
VISION_API_BASE_URL=http://localhost:8000
VISION_DETECTOR=yolo
# Keep this as a model name unless you need to force a specific local path.
# The vision sidecar will prefer apps/vision-lab/checkpoints/base/yolo11n.pt
# when that shared checkpoint exists.
VISION_YOLO_MODEL=yolo11n.pt
# Crop classification lets the app show ingredient names like rice after YOLO
# proposes a generic object box such as bowl/container.
VISION_CLASSIFY_CROPS=true
# The sidecar resolves this to:
# apps/vision-lab/checkpoints/classifiers/ingredient/<run>/best_model.pt
VISION_CLASSIFIER_RUN=resnet18_ingredient_crops_5000_modal_frozen_v2
# Optional explicit classifier checkpoint path if you want to bypass run lookup.
VISION_CLASSIFIER_CHECKPOINT=
VISION_CLASSIFIER_TOP_K=5
VISION_CLASSIFIER_MIN_CONFIDENCE=0.15
VISION_USE_FULL_IMAGE_FALLBACK=false
VISION_FULL_IMAGE_MIN_CONFIDENCE=0.15
VISION_USE_GRID_FALLBACK=false
VISION_GRID_MAX_CROPS=24
VISION_GRID_CROP_FRACTION=0.35
VISION_GRID_STRIDE_FRACTION=0.5
VISION_GRID_MIN_CONFIDENCE=0.65
VISION_GRID_MAX_ADDITIONS=0
VISION_MEDIA_UPLOAD_MAX_BYTES=26214400

# Google auth
# Used by the API to verify Google ID tokens.
GOOGLE_CLIENT_ID=
# Optional backend OAuth client secret if a provider flow requires it.
GOOGLE_CLIENT_SECRET=
# Used by the web Google sign-in button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Kroger live product search
# Keep false unless you have valid credentials.
KROGER_USE_REAL_PROVIDER=false
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Instacart Developer Platform handoff
# Development base URL: https://connect.dev.instacart.tools
# Production base URL: https://connect.instacart.com
INSTACART_USE_REAL_PROVIDER=false
INSTACART_API_KEY=
INSTACART_ENV=development
INSTACART_API_BASE_URL=https://connect.dev.instacart.tools

# Walmart provider boundary
# Currently inactive by default.
WALMART_USE_REAL_PROVIDER=false
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
WALMART_ENV=sandbox

# LLM recipe generation and editing
# mock works in the Streamlit testing lab without API keys.
CHEF_LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AI_RATE_LIMIT_WINDOW_MS=600000
AI_RATE_LIMIT_MAX_REQUESTS=5
OPENAI_REQUEST_TIMEOUT_MS=120000
IMPORT_URL_FETCH_TIMEOUT_MS=8000
IMPORT_URL_FETCH_MAX_BYTES=1000000

# Web voice features (ElevenLabs)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Unsplash image search for recipe image enrichment
UNSPLASH_ACCESS_KEY=
# Deployment/runtime toggles
# Keep false in production unless you intentionally want demo/local seed data
# applied on every API container start.
RUN_DB_SEED_ON_STARTUP=false
