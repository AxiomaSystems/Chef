    "name": "Cart Generator API Negative",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Negative-path checks for the current /api/v1 Cart Generator backend."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "requestId",
      "value": "postman-negative"
    },
    {
      "key": "authEmail",
      "value": "postigodev@cart-generator.local"
    },
    {
      "key": "authPassword",
      "value": "postigodev123"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "systemRecipeId",
      "value": ""
    },
    {
      "key": "userTagId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Auth / Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-login"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Recipes / List Recipes (authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "const systemRecipe = Array.isArray(data) ? data.find((recipe) => recipe.is_system_recipe === true) : null;",
                  "pm.test('system recipe exists', function () {",
                  "  pm.expect(systemRecipe && systemRecipe.id).to.be.a('string');",
                  "});",
                  "",
                  "if (systemRecipe && systemRecipe.id) {",
                  "  pm.collectionVariables.set('systemRecipeId', systemRecipe.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-recipes-auth"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/recipes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "recipes"
              ]
            }
          }
        },
        {
          "name": "Tags / Create User Tag",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 200', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('userTagId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-tag-create"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Negative QA Tag\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tags",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tags"
              ]
            }
          }
        }
      ]
