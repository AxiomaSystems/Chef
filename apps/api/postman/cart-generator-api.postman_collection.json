              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-recipes-create"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tallarines verdes caseros\",\n  \"cuisine\": \"Peruvian\",\n  \"description\": \"Pasta with herb sauce\",\n  \"servings\": 4,\n  \"ingredients\": [\n    {\n      \"canonical_ingredient\": \"pasta\",\n      \"amount\": 500,\n      \"unit\": \"g\"\n    },\n    {\n      \"canonical_ingredient\": \"cilantro\",\n      \"amount\": 2,\n      \"unit\": \"cup\"\n    }\n  ],\n  \"steps\": [\n    {\n      \"step\": 1,\n      \"what_to_do\": \"Boil the pasta.\"\n    },\n    {\n      \"step\": 2,\n      \"what_to_do\": \"Blend the herb sauce and combine.\"\n    }\n  ],\n  \"tags\": [\"dinner\", \"pasta\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recipes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "recipes"
              ]
            }
          }
