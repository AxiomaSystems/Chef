      "name": "Recipes",
      "item": [
        {
          "name": "List Recipes (Authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('response is an array', function () {",
                  "  pm.expect(Array.isArray(data)).to.eql(true);",
                  "});",
                  "",
                  "if (Array.isArray(data)) {",
                  "  const systemRecipe = data.find((recipe) => recipe.is_system_recipe === true);",
                  "  const ownedRecipe = data.find((recipe) => recipe.is_system_recipe === false && recipe.owner_user_id);",
                  "",
                  "  if (systemRecipe && systemRecipe.id) {",
                  "    pm.collectionVariables.set('systemRecipeId', systemRecipe.id);",
                  "  }",
                  "",
                  "  if (ownedRecipe && ownedRecipe.id) {",
                  "    pm.collectionVariables.set('recipeId', ownedRecipe.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-recipes-auth"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/recipes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "recipes"
              ]
            }
          }
        },
        {
          "name": "List Recipes (Unauthenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('unauthenticated recipes are only system recipes', function () {",
                  "  pm.expect(Array.isArray(data)).to.eql(true);",
                  "  data.forEach((recipe) => pm.expect(recipe.is_system_recipe).to.eql(true));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-request-id",
                "value": "{{requestId}}-recipes-public"
              }
