        {
          "name": "Create Recipe",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 200', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('created recipe has id', function () {",
                  "  pm.expect(data.id).to.be.a('string');",
                  "  pm.expect(data.is_system_recipe).to.eql(false);",
                  "});",
                  "",
                  "pm.collectionVariables.set('recipeId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
