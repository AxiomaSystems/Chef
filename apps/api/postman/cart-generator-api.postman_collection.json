{
  "info": {
    "_postman_id": "4cd9e4c8-31d8-4b55-a1de-b856ea6af802",
    "name": "Cart Generator API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Compact happy-path collection for the current /api/v1 backend."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "requestId", "value": "postman-local" },
    { "key": "authEmail", "value": "postigodev@cart-generator.local" },
    { "key": "authPassword", "value": "postigodev123" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "cuisineId", "value": "" },
    { "key": "systemTagId", "value": "" },
    { "key": "userTagId", "value": "" },
    { "key": "recipeId", "value": "" },
    { "key": "cartId", "value": "" },
    { "key": "shoppingCartId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth / Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('accessToken', data.access_token);",
              "pm.collectionVariables.set('refreshToken', data.refresh_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-request-id", "value": "{{requestId}}-auth-login" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Taxonomies / List Cuisines",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "if (Array.isArray(data) && data.length > 0) { pm.collectionVariables.set('cuisineId', data[0].id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-request-id", "value": "{{requestId}}-cuisines" }
        ],
        "url": "{{baseUrl}}/api/v1/cuisines"
      }
    },
    {
      "name": "Taxonomies / List Tags",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "if (Array.isArray(data)) { const systemTag = data.find((tag) => tag.scope === 'system'); if (systemTag) { pm.collectionVariables.set('systemTagId', systemTag.id); } }"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-tags-list" }
        ],
        "url": "{{baseUrl}}/api/v1/tags"
      }
    },
    {
      "name": "Tags / Create User Tag",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201 or 200', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('userTagId', data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-tags-create" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"QA Favorites\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/tags"
      }
    },
    {
      "name": "Me / Get Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-me-get" }
        ],
        "url": "{{baseUrl}}/api/v1/me"
      }
    },
    {
      "name": "Me / Put Preferences",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-me-preferences" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"preferred_cuisine_ids\": [\"{{cuisineId}}\"],\n  \"preferred_tag_ids\": [\"{{systemTagId}}\"],\n  \"shopping_location\": {\n    \"zip_code\": \"60611\",\n    \"label\": \"Chicago, IL\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/v1/me/preferences"
      }
    },
    {
      "name": "Recipes / List Recipes (Public)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-request-id", "value": "{{requestId}}-recipes-public" }
        ],
        "url": "{{baseUrl}}/api/v1/recipes"
      }
    },
    {
      "name": "Recipes / Create Recipe",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.id) { pm.collectionVariables.set('recipeId', data.id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-recipes-create" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"QA Arroz con pollo\",\n  \"cuisine_id\": \"{{cuisineId}}\",\n  \"description\": \"Recipe created from Postman.\",\n  \"servings\": 4,\n  \"ingredients\": [\n    {\n      \"canonical_ingredient\": \"rice\",\n      \"amount\": 2,\n      \"unit\": \"cup\"\n    },\n    {\n      \"canonical_ingredient\": \"chicken thigh\",\n      \"amount\": 800,\n      \"unit\": \"g\"\n    }\n  ],\n  \"steps\": [\n    {\n      \"step\": 1,\n      \"what_to_do\": \"Brown the chicken thighs.\"\n    },\n    {\n      \"step\": 2,\n      \"what_to_do\": \"Add rice and simmer until cooked.\"\n    }\n  ],\n  \"tag_ids\": [\"{{systemTagId}}\", \"{{userTagId}}\"]\n}"
        },
        "url": "{{baseUrl}}/api/v1/recipes"
      }
    },
    {
      "name": "Cart / Create Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.id) { pm.collectionVariables.set('cartId', data.id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-cart-create" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"QA Weekly dinner plan\",\n  \"retailer\": \"walmart\",\n  \"selections\": [\n    {\n      \"recipe_id\": \"{{recipeId}}\",\n      \"recipe_type\": \"base\",\n      \"quantity\": 2,\n      \"servings_override\": 4\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/v1/carts"
      }
    },
    {
      "name": "Cart / Create Shopping Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.id) { pm.collectionVariables.set('shoppingCartId', data.id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-shopping-cart-create" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"retailer\": \"walmart\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/carts/{{cartId}}/shopping-carts"
      }
    },
    {
      "name": "Cart / Search Retailer Products",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-request-id", "value": "{{requestId}}-retailer-search" }
        ],
        "url": "{{baseUrl}}/api/v1/retailers/walmart/products/search?query=rice"
      }
    }
  ]
}
