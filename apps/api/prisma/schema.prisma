generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model DatabaseReleaseCompatibility {
  id                  Int      @id
  minimumApiMigration String
  updatedAt           DateTime @updatedAt
}

enum UserRole {
  admin
  user
}

enum AuthProvider {
  google
  password
}

enum TagScope {
  system
  user
}

enum TagKind {
  general
  dietary_badge
}

enum CuisineKind {
  national
  regional
  cultural
  style
  other
}

enum KitchenInventorySource {
  manual
  cart
  vision
  receipt
  inferred
  seed
}

enum KitchenInventoryConfidence {
  low
  medium
  high
}

enum InventoryReviewStatus {
  pending
  active
  discarded
  archived
}

enum VisionObservationAction {
  pending
  added_to_inventory
  renamed
  discarded
  resolved_to_ingredient
}

enum CaptureInputKind {
  url
  text
  image
}

enum CaptureSourceKind {
  recipe_url
  social_url
  pasted_text
  image
  unknown
}

enum CaptureResultKind {
  exact_recipe_import
  partial_recipe_import
  reconstructed_recipe
  inspired_recipe
}

enum CaptureStatus {
  processing
  ready_for_review
  needs_more_info
  failed
  saved
  discarded
}

enum CaptureConfidence {
  low
  medium
  high
}

enum RecipeDifficulty {
  easy
  medium
  hard
}

enum RecipeCostTier {
  low
  medium
  high
}

enum RecipeSourceType {
  user_created
  ai_generated
  recipe_url
  social_url
  pasted_text
  image
  unknown
}

enum RecipeReviewStatus {
  draft
  needs_review
  reviewed
  trusted
}

enum RecipeExtractionConfidence {
  low
  medium
  high
}

enum RecipeTemperatureUnit {
  F
  C
}

enum CartStatus {
  active
  archived
}

enum ShoppingCartStatus {
  active
  checked_out
  archived
}

enum MealType {
  breakfast
  brunch
  lunch
  dinner
  snack
  dessert
  side
  appetizer
  drink
}

enum UserFoodRuleKind {
  dietary_constraint
  ingredient_preference
  texture_preference
}

enum UserFoodRuleAction {
  prefer
  dislike
  avoid
  require
}

enum UserRuleStrictness {
  soft
  hard
}

enum UserMemorySource {
  onboarding
  manual
  behavior
  inferred
  import
}

enum UserMemoryConfidence {
  low
  medium
  high
}

enum UserGoalKind {
  save_money
  save_time
  eat_healthier
  hit_protein
  reduce_waste
  try_new_foods
  cook_more_at_home
  meal_prep
  spend_less_on_takeout
}

enum UserGoalTimeframe {
  default_timeframe
  this_week
  long_term
}

model User {
  id                        String                 @id @default(cuid())
  email                     String                 @unique
  name                      String
  role                      UserRole               @default(user)
  onboardingCompletedAt     DateTime?
  householdSize             String?
  kidsProfile               String?
  favoriteProteins          Json?
  favoriteFlavors           Json?
  spiceLevel                String?
  dislikedIngredients       Json?
  dislikedTextures          Json?
  cookingSkillLevel         String?
  availableAppliances       Json?
  preferredCookingTime      String?
  typicalMealTimes          Json?
  goalPriorities            Json?
  calorieTrackingMode       String?
  weeklyNutritionTargets    Json?
  weeklyBudget              String?
  preferredStores           Json?
  shoppingMode              String?
  recipeDiscoverySources    Json?
  biggestCookingFrustration String?
  aiPlanningOptimization    String?
  preferredZipCode          String?
  preferredLocationLabel    String?
  preferredLatitude         Float?
  preferredLongitude        Float?
  preferredKrogerLocationId String?
  savedAddresses            Json?
  paymentCards              Json?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  authIdentities            AuthIdentity[]
  refreshTokens             RefreshToken[]
  ownedTags                 Tag[]
  ownedRecipes              BaseRecipe[]
  cartDrafts                CartDraft[]
  carts                     Cart[]
  shoppingCarts             ShoppingCart[]
  captures                  Capture[]
  preferredCuisines         UserPreferredCuisine[]
  preferredTags             UserPreferredTag[]
  kitchenInventoryItems     KitchenInventoryItem[]
  visionObservations        VisionObservation[]
  mealPlans                 MealPlan[]
  mealEvents                MealEvent[]
  foodRules                 UserFoodRule[]
  goals                     UserGoal[]
  pantryStaples             UserPantryStaple[]
}

model AuthIdentity {
  id              String       @id @default(cuid())
  userId          String
  provider        AuthProvider
  providerSubject String
  email           String
  emailVerified   Boolean      @default(false)
  passwordHash    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId, provider])
  @@index([email])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model BaseRecipe {
  id                 String           @id @default(cuid())
  ownerUserId        String?
  forkedFromRecipeId String?
  cuisineId          String
  isSystemRecipe     Boolean          @default(false)
  name               String
  description        String?
  coverImageUrl      String?
  nutritionData      Json?
  servings           Int
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  cuisine            Cuisine          @relation(fields: [cuisineId], references: [id], onDelete: Restrict)
  owner              User?            @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  forkedFromRecipe   BaseRecipe?      @relation("ForkedRecipeSource", fields: [forkedFromRecipeId], references: [id], onDelete: SetNull)
  forkedRecipes      BaseRecipe[]     @relation("ForkedRecipeSource")
  ingredients        DishIngredient[]
  planningProfile    RecipePlanningProfile?
  mealTypes          RecipeMealType[]
  provenanceProfile  RecipeProvenanceProfile?
  recipeTags         RecipeTag[]
  steps              RecipeStep[]
  sourceCapture      Capture?
  mealEvents         MealEvent[]

  @@unique([ownerUserId, forkedFromRecipeId])
  @@index([ownerUserId, createdAt])
  @@index([ownerUserId, isSystemRecipe, forkedFromRecipeId, createdAt, id])
  @@index([forkedFromRecipeId])
  @@index([isSystemRecipe, createdAt])
  @@index([isSystemRecipe, ownerUserId, createdAt, id])
  @@index([cuisineId])
  @@index([cuisineId, createdAt, id])
}

model Cuisine {
  id               String                 @id @default(cuid())
  slug             String                 @unique
  label            String
  kind             CuisineKind
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  recipes          BaseRecipe[]
  preferredByUsers UserPreferredCuisine[]

  @@index([kind, label])
}

model Tag {
  id               String             @id @default(cuid())
  ownerUserId      String?
  name             String
  slug             String
  scope            TagScope
  kind             TagKind            @default(general)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  owner            User?              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  recipeTags       RecipeTag[]
  preferredByUsers UserPreferredTag[]
  foodRules        UserFoodRule[]

  @@index([scope, name])
  @@index([scope, kind, name])
  @@index([scope, slug])
  @@index([ownerUserId, scope, slug])
  @@unique([id, scope])
}

model UserPreferredCuisine {
  userId    String
  cuisineId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuisine   Cuisine  @relation(fields: [cuisineId], references: [id], onDelete: Cascade)

  @@id([userId, cuisineId])
  @@index([cuisineId])
}

model UserPreferredTag {
  userId    String
  tagId     String
  tagScope  TagScope @default(system)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId, tagScope], references: [id, scope], onDelete: Cascade)

  @@id([userId, tagId])
  @@index([tagId, tagScope])
}

model UserFoodRule {
  id              String               @id @default(cuid())
  userId          String
  kind            UserFoodRuleKind
  label           String
  normalizedLabel String
  dedupeKey       String
  ingredientId    String?
  tagId           String?
  action          UserFoodRuleAction
  strictness      UserRuleStrictness
  active          Boolean              @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?
  source          UserMemorySource
  confidence      UserMemoryConfidence @default(high)
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient      Ingredient?          @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  tag             Tag?                 @relation(fields: [tagId], references: [id], onDelete: SetNull)

  @@unique([userId, dedupeKey])
  @@index([userId, kind])
  @@index([userId, strictness])
  @@index([userId, strictness, createdAt])
  @@index([userId, active, startsAt, expiresAt])
  @@index([ingredientId])
  @@index([tagId])
}

model UserGoal {
  id         String               @id @default(cuid())
  userId     String
  goal       UserGoalKind
  priority   Int
  active     Boolean              @default(true)
  startsAt   DateTime?
  expiresAt  DateTime?
  timeframe  UserGoalTimeframe    @default(default_timeframe)
  source     UserMemorySource     @default(onboarding)
  confidence UserMemoryConfidence @default(high)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, goal, timeframe])
  @@index([userId, active, priority])
  @@index([userId, active, startsAt, expiresAt])
  @@index([userId, priority, createdAt])
}

model UserPantryStaple {
  userId       String
  ingredientId String
  source       UserMemorySource     @default(onboarding)
  confidence   UserMemoryConfidence @default(high)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient   Ingredient           @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([userId, ingredientId])
  @@index([ingredientId])
  @@index([userId, createdAt])
}

model RecipeTag {
  recipeId String
  tagId    String
  recipe   BaseRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
  @@index([tagId])
  @@index([tagId, recipeId])
}

model RecipePlanningProfile {
  recipeId          String          @id
  difficulty        RecipeDifficulty?
  difficultyReason  String?
  prepTimeMinutes   Int?
  cookTimeMinutes   Int?
  totalTimeMinutes  Int?
  estimatedCostTier RecipeCostTier?
  costNotes         Json            @default("[]")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  recipe            BaseRecipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([difficulty])
  @@index([estimatedCostTier])
}

model RecipeMealType {
  recipeId String
  mealType MealType
  recipe   BaseRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([recipeId, mealType])
  @@index([mealType, recipeId])
}

model RecipeProvenanceProfile {
  recipeId              String                       @id
  sourceType            RecipeSourceType             @default(user_created)
  sourceUrl             String?
  sourceName            String?
  attributionLabel      String?
  reviewStatus          RecipeReviewStatus           @default(reviewed)
  extractionConfidence  RecipeExtractionConfidence?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  recipe                BaseRecipe                   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([sourceType])
  @@index([reviewStatus])
}

model DishIngredient {
  id                  String                 @id @default(cuid())
  baseRecipeId        String
  ingredientId        String?
  canonicalIngredient String
  amount              Float?
  unit                String?
  amountText          String?
  displayIngredient   String?
  preparation         String?
  substitutions       Json                   @default("[]")
  optional            Boolean                @default(false)
  ingredientGroup     String?
  sortOrder           Int
  baseRecipe          BaseRecipe             @relation(fields: [baseRecipeId], references: [id], onDelete: Cascade)
  ingredient          Ingredient?            @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  stepLinks           RecipeStepIngredient[]

  @@unique([baseRecipeId, sortOrder])
  @@index([ingredientId])
  @@index([baseRecipeId, ingredientId])
}

model Ingredient {
  id                    String                 @id @default(cuid())
  canonicalName         String
  slug                  String                 @unique
  aliases               Json?
  category              String?
  defaultUnit           String?
  visionLabels          Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  dishIngredients       DishIngredient[]
  kitchenInventoryItems KitchenInventoryItem[]
  foodRules             UserFoodRule[]
  pantryStaples         UserPantryStaple[]

  @@index([canonicalName])
  @@index([category, canonicalName])
}

model KitchenInventoryItem {
  id              String                     @id @default(cuid())
  userId          String
  ingredientId    String?
  displayName     String
  normalizedName  String
  label           String?
  estimatedAmount Float?
  unit            String?
  source          KitchenInventorySource     @default(manual)
  confidence      KitchenInventoryConfidence @default(medium)
  reviewStatus    InventoryReviewStatus      @default(active)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient      Ingredient?                @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  observations    VisionObservation[]

  @@index([userId, reviewStatus, updatedAt])
  @@index([userId, normalizedName])
  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([ingredientId])
}

model VisionObservation {
  id              String                  @id @default(cuid())
  userId          String?
  inventoryItemId String?
  detectedLabel   String
  proposedName    String?
  canonicalSlug   String?
  detectorModel   String?
  classifierModel String?
  modelName       String?
  confidence      Float?
  imageRef        String?
  cropRef         String?
  bbox            Json?
  rawPayload      Json?
  action          VisionObservationAction @default(pending)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  user            User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  inventoryItem   KitchenInventoryItem?   @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([inventoryItemId])
  @@index([detectedLabel])
  @@index([canonicalSlug])
  @@index([action, createdAt])
}

model RecipeStep {
  id              String                 @id @default(cuid())
  baseRecipeId    String
  stepNumber      Int
  whatToDo        String
  durationMinutes Int?
  temperature     Int?
  temperatureUnit RecipeTemperatureUnit?
  timerLabel      String?
  equipment       Json                   @default("[]")
  baseRecipe      BaseRecipe             @relation(fields: [baseRecipeId], references: [id], onDelete: Cascade)
  ingredientLinks RecipeStepIngredient[]

  @@unique([baseRecipeId, stepNumber])
}

model RecipeStepIngredient {
  recipeStepId     String
  dishIngredientId String
  recipeStep       RecipeStep      @relation(fields: [recipeStepId], references: [id], onDelete: Cascade)
  dishIngredient   DishIngredient  @relation(fields: [dishIngredientId], references: [id], onDelete: Cascade)

  @@id([recipeStepId, dishIngredientId])
  @@index([recipeStepId])
  @@index([dishIngredientId])
}

model CartDraft {
  id            String         @id @default(cuid())
  userId        String
  name          String?
  selections    Json
  retailer      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoppingCarts ShoppingCart[]

  @@index([userId, createdAt])
}

model Cart {
  id               String            @id @default(cuid())
  userId           String
  name             String?
  retailer         String
  status           CartStatus        @default(active)
  selections       Json
  dishes           Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ingredientReview IngredientReview?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoppingCarts    ShoppingCart[]

  @@index([userId, createdAt])
  @@index([userId, status, updatedAt])
}

model IngredientReview {
  id        String   @id @default(cuid())
  cartId    String   @unique
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model ShoppingCart {
  id                  String             @id @default(cuid())
  userId              String
  cartId              String
  cartDraftId         String?
  name                String?
  retailer            String
  status              ShoppingCartStatus @default(active)
  overview            Json
  matchedItems        Json
  estimatedSubtotal   Float
  estimatedTotal      Float?
  externalUrl         String?
  externalReferenceId String?
  checkedOutAt        DateTime?
  inventoryAppliedAt  DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cart                Cart               @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartDraft           CartDraft?         @relation(fields: [cartDraftId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, status, updatedAt])
  @@index([cartId, userId])
  @@index([cartDraftId, userId])
}

model MealPlan {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  days      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

model MealEvent {
  id          String     @id @default(cuid())
  userId      String
  date        DateTime   @db.Date
  sortOrder   Int        @default(0)
  mealLabel   String     @default("dinner")
  customLabel String?
  sourceType  String     @default("recipe")
  recipeId    String?
  title       String
  servings    Int        @default(1)
  status      String     @default("planned")
  locked      Boolean    @default(false)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe      BaseRecipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, date, sortOrder])
  @@index([userId, status, date])
  @@index([recipeId])
}

model Capture {
  id                String            @id @default(cuid())
  userId            String
  inputKind         CaptureInputKind
  sourceKind        CaptureSourceKind
  resultKind        CaptureResultKind
  status            CaptureStatus     @default(ready_for_review)
  confidence        CaptureConfidence @default(medium)
  needsReview       Boolean           @default(true)
  savedRecipeId     String?           @unique
  sourceUrl         String?
  sourceTextSnippet String?
  attribution       Json
  recipePreview     Json?
  assumptions       Json
  missingInfo       Json
  nextActions       Json
  extractionNotes   Json
  shortSnippets     Json
  errorMessage      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedRecipe       BaseRecipe?       @relation(fields: [savedRecipeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([sourceKind, createdAt])
}
